generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          String         @default("READ")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  allowedScopes UserLocation[]
  movements     StockMovement[]
  reservations  Reservation[]
  auditLogs     AuditLog[]
  favorites     Favorite[]
  recentViews   RecentView[]
  accounts      Account[]
  sessions      Session[]
  apiTokens     ApiToken[]
  ownedInventorySessions InventorySession[]    @relation("InventorySessionOwner")
  createdInventorySessions InventorySession[]  @relation("InventorySessionCreator")
  countedInventorySessionRows InventorySessionRow[] @relation("InventorySessionRowCounter")
}

model UserLocation {
  id                String           @id @default(uuid())
  userId            String
  storageLocationId String
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  storageLocation   StorageLocation  @relation(fields: [storageLocationId], references: [id], onDelete: Cascade)

  @@unique([userId, storageLocationId])
}

model Category {
  id            String            @id @default(uuid())
  name          String            @unique
  code          String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         Item[]
  customFields  CustomField[]
  labelCounters CategoryTypeCounter[]
  technicalFieldAssignments TechnicalFieldScopeAssignment[]
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  itemTags  ItemTag[]
}

model StorageLocation {
  id        String         @id @default(uuid())
  name      String         @unique
  code      String?        @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     Item[]
  scopes    UserLocation[]
  shelves   StorageShelf[]
  bins      StorageBin[]
  inventorySessions InventorySession[]
}

model StorageShelf {
  id                String          @id @default(uuid())
  storageLocationId String
  name              String
  code              String?
  description       String?
  mode              String          @default("OPEN_AREA")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  storageLocation   StorageLocation @relation(fields: [storageLocationId], references: [id], onDelete: Cascade)
  items             Item[]
  bins              StorageBin[]

  @@unique([storageLocationId, name])
  @@unique([storageLocationId, code])
  @@index([storageLocationId])
}

model StorageBin {
  id                String          @id @default(uuid())
  code              String
  storageLocationId String
  storageShelfId    String
  storageArea       String?
  slotCount         Int             @default(1)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  storageLocation   StorageLocation @relation(fields: [storageLocationId], references: [id], onDelete: Cascade)
  storageShelf      StorageShelf    @relation(fields: [storageShelfId], references: [id], onDelete: Cascade)
  items             Item[]

  @@unique([storageShelfId, code])
  @@index([storageShelfId])
  @@index([storageLocationId, storageArea])
}

model Area {
  id        String       @id @default(uuid())
  code      String       @unique
  name      String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  types     LabelType[]
  counters  SequenceCounter[]

  @@unique([code, name])
}

model LabelType {
  id               String              @id @default(uuid())
  areaId           String
  code             String
  name             String
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  area             Area                @relation(fields: [areaId], references: [id], onDelete: Cascade)
  counters         SequenceCounter[]
  customFields     CustomField[]
  categoryCounters CategoryTypeCounter[]
  technicalFieldAssignments TechnicalFieldScopeAssignment[]
  items            Item[]

  @@unique([areaId, code])
}

model SequenceCounter {
  id         String    @id @default(uuid())
  areaId     String
  typeId     String
  nextNumber Int       @default(1)
  area       Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)
  type       LabelType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([areaId, typeId])
}

model CategoryTypeCounter {
  id         String    @id @default(uuid())
  categoryId String
  typeId     String
  nextNumber Int       @default(1)
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type       LabelType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([categoryId, typeId])
  @@index([typeId])
}

model LabelConfig {
  id                String   @id @default("default")
  language          String   @default("de")
  separator         String   @default("-")
  digits            Int      @default(3)
  prefix            String?
  suffix            String?
  recycleNumbers    Boolean  @default(false)
  delimiter         String   @default(",")
  allowCodeEdit     Boolean  @default(true)
  regenerateOnType  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Item {
  id                String              @id @default(uuid())
  labelCode         String              @unique
  name              String
  description       String
  categoryId        String
  typeId            String?
  storageLocationId String?
  storageShelfId    String?
  storageArea       String?
  storageBinId      String?
  binSlot           Int?
  placementStatus   String              @default("PLACED")
  stock             Int                 @default(0)
  incomingQty       Int                 @default(0)
  unit              String              @default("STK")
  minStock          Int?
  manufacturer      String?
  mpn               String?
  datasheetUrl      String?
  purchaseUrl       String?
  isArchived        Boolean             @default(false)
  deletedAt         DateTime?
  mergedIntoItemId  String?
  mergedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  category          Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  labelType         LabelType?          @relation(fields: [typeId], references: [id], onDelete: SetNull)
  storageLocation   StorageLocation?    @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  storageShelf      StorageShelf?       @relation(fields: [storageShelfId], references: [id], onDelete: SetNull)
  storageBin        StorageBin?         @relation(fields: [storageBinId], references: [id], onDelete: SetNull)
  mergedIntoItem    Item?               @relation("MergedItems", fields: [mergedIntoItemId], references: [id], onDelete: SetNull)
  mergedSourceItems Item[]              @relation("MergedItems")
  tags              ItemTag[]
  images            ItemImage[]
  attachments       Attachment[]
  movements         StockMovement[]
  reservations      Reservation[]
  customValues      ItemCustomFieldValue[]
  favorites         Favorite[]
  recentViews       RecentView[]
  bomParents        BillOfMaterial[]    @relation("BOMChild")
  bomChildren       BillOfMaterial[]    @relation("BOMParent")
  inventorySessionRows InventorySessionRow[]

  @@index([name])
  @@index([labelCode])
  @@index([mpn])
  @@index([manufacturer])
  @@index([typeId])
  @@index([storageLocationId])
  @@index([storageShelfId])
  @@index([storageBinId])
  @@index([placementStatus])
  @@index([storageBinId, binSlot])
  @@index([deletedAt])
  @@index([mergedIntoItemId])
  @@index([minStock, stock])
  @@unique([storageBinId, binSlot])
}

model ItemTag {
  itemId String
  tagId  String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model ItemImage {
  id        String   @id @default(uuid())
  itemId    String
  path      String
  thumbPath String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  mime      String
  size      Int
  caption   String?
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, isPrimary])
  @@index([itemId, sortOrder])
}

model Attachment {
  id        String         @id @default(uuid())
  itemId    String
  path      String
  mime      String
  size      Int
  kind      String
  createdAt DateTime       @default(now())
  item      Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id        String         @id @default(uuid())
  itemId    String
  inventorySessionId String?
  delta     Int
  reason    String
  note      String?
  userId    String
  createdAt DateTime       @default(now())
  item      Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  inventorySession InventorySession? @relation(fields: [inventorySessionId], references: [id], onDelete: SetNull)
  user      User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([itemId, createdAt])
  @@index([inventorySessionId])
}

model Reservation {
  id          String   @id @default(uuid())
  itemId       String
  reservedQty  Int
  reservedFor  String
  note         String?
  userId       String
  createdAt    DateTime @default(now())
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([itemId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  before    String?
  after     String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}

model CustomField {
  id                             String                          @id @default(uuid())
  name                           String
  key                            String                          @unique
  type                           String
  unit                           String?
  options                        String?
  valueCatalog                   String?
  sortOrder                      Int                             @default(0)
  required                       Boolean                         @default(false)
  categoryId                     String?
  typeId                         String?
  technicalFieldScopeAssignmentId String?
  managedPresetKey               String?
  managedPresetFieldKey          String?
  isActive                       Boolean                         @default(true)
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  category                       Category?                       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  labelType                      LabelType?                      @relation(fields: [typeId], references: [id], onDelete: SetNull)
  technicalFieldScopeAssignment  TechnicalFieldScopeAssignment?  @relation(fields: [technicalFieldScopeAssignmentId], references: [id], onDelete: SetNull)
  values                         ItemCustomFieldValue[]

  @@unique([name, categoryId, typeId])
  @@index([typeId])
  @@index([technicalFieldScopeAssignmentId])
  @@index([managedPresetKey, managedPresetFieldKey])
}

model TechnicalFieldScopeAssignment {
  id        String      @id @default(uuid())
  categoryId String
  typeId    String
  presetKey String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  category  Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  labelType LabelType   @relation(fields: [typeId], references: [id], onDelete: Cascade)
  managedFields CustomField[]

  @@unique([categoryId, typeId])
  @@index([typeId])
}

model ImportProfile {
  id               String   @id @default(uuid())
  name             String   @unique
  description      String?
  headerFingerprint String?
  delimiterMode    String   @default("AUTO")
  mappingConfig    String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([headerFingerprint])
}

model InventorySession {
  id                String                @id @default(uuid())
  title             String?
  status            String                @default("OPEN")
  storageLocationId String
  storageArea       String?
  ownerUserId       String
  createdByUserId   String?
  note              String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  finalizedAt       DateTime?
  cancelledAt       DateTime?
  storageLocation   StorageLocation       @relation(fields: [storageLocationId], references: [id], onDelete: Restrict)
  ownerUser         User                  @relation("InventorySessionOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  createdByUser     User?                 @relation("InventorySessionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rows              InventorySessionRow[]
  stockMovements    StockMovement[]

  @@index([storageLocationId, status])
  @@index([ownerUserId, status])
  @@index([createdByUserId])
}

model InventorySessionRow {
  id              String            @id @default(uuid())
  sessionId       String
  itemId          String
  labelCode       String
  name            String
  unit            String
  storageArea     String?
  storageShelfCode String?
  storageBinCode  String?
  binSlot         Int?
  expectedStock   Int
  countedStock    Int?
  countedByUserId String?
  countedAt       DateTime?
  note            String?
  session         InventorySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item            Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)
  countedByUser   User?             @relation("InventorySessionRowCounter", fields: [countedByUserId], references: [id], onDelete: SetNull)

  @@unique([sessionId, itemId])
  @@index([itemId])
  @@index([countedByUserId])
}

model ItemCustomFieldValue {
  id            String      @id @default(uuid())
  itemId         String
  customFieldId  String
  valueJson      String
  item           Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  customField    CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([itemId, customFieldId])
  @@index([customFieldId])
}

model Favorite {
  userId    String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
}

model RecentView {
  userId       String
  itemId       String
  lastViewedAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([lastViewedAt])
}

model BillOfMaterial {
  id          String @id @default(uuid())
  parentItemId String
  childItemId  String
  qty         Int    @default(1)
  parent      Item   @relation("BOMParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  child       Item   @relation("BOMChild", fields: [childItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, childItemId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiToken {
  id         String   @id @default(uuid())
  name       String
  tokenHash  String   @unique
  isActive   Boolean  @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}
